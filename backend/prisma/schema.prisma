// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id  @default(uuid())
  email     String  @unique
  password  String  
  balances  Balance[]
  orders     Order[]
}

model Balance{
  id        String  @id @default(uuid())
  userId    String  
  asset     String
  locked    Float 
  available Float
  user      User   @relation(fields: [userId], references: [id])

  @@unique([userId, asset])
}
 

model Order {
  id                String          @id @default(uuid())
  userId            String
  symbol            String         
  side              Side
  type              OrderType
  price             Float
  quantity          Float
  filledQuantity    Float           @default(0)
  status            OrderStatus
  createdAt         DateTime        @default(now())

  user              User            @relation(fields: [userId], references: [id])
              
  buyFills          Fill[]          @relation("BuyOrder")
  sellFills         Fill[]          @relation("SellOrder")
}

model Fill {
  id            String    @id @default(uuid())
  
  buyOrderId    String
  sellOrderId   String

  price         Float
  quantity      Float
  symbol         String

  buyOrder        Order       @relation("BuyOrder", fields: [buyOrderId],  references: [id])
  sellOrder       Order       @relation("SellOrder", fields: [sellOrderId], references: [id])
  createdAt     DateTime     @default(now())
}


enum Side{
  BUY
  SELL
}


enum OrderType{
  LIMIT
  MARKET
}


enum OrderStatus{
  OPEN
  PARTIAL
  CANCELLED
  FILLED
}

